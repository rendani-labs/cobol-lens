{
  "name": "cobol-lens",
  "displayName": "COBOL Lens",
  "description": "COBOL tooling tailored for the Micro Focus / Rocket COBOL dialect: syntax highlighting, Go to Definition, Peek, Find All References, hover with field size, copybook autocomplete, code folding, and a 47-rule integrated linter. No compiler required.",
  "version": "1.12.1",
  "publisher": "rendani-labs",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/rendani-labs/cobol-lens"
  },
  "bugs": {
    "url": "https://github.com/rendani-labs/cobol-lens/issues"
  },
  "homepage": "https://github.com/rendani-labs/cobol-lens#readme",
  "keywords": [
    "cobol",
    "copybook",
    "copybooks",
    "linter",
    "mainframe",
    "ibm",
    "cbl",
    "micro focus",
    "rocket cobol",
    "enterprise developer",
    "go to definition",
    "references",
    "navigation",
    "intellisense",
    "fixed format",
    "variable format"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:COBOL",
    "workspaceContains:**/*.CBL",
    "workspaceContains:**/*.clt",
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cobol",
        "aliases": [
          "COBOL",
          "cobol"
        ],
        "extensions": [
          ".cbl",
          ".CBL",
          ".cob",
          ".COB",
          ".cobol",
          ".COBOL",
          ".cpy",
          ".CPY",
          ".copy",
          ".COPY",
          ".clt",
          ".CLT",
          ".pco",
          ".PCO"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "cobol",
        "scopeName": "source.cobol.lens",
        "path": "./syntaxes/cobol.tmLanguage.json"
      }
    ],
    "keybindings": [
      {
        "command": "editor.showCallHierarchy",
        "key": "ctrl+alt+h",
        "when": "editorTextFocus && editorLangId == cobol"
      },
      {
        "command": "cobolLens.toggleComment",
        "key": "ctrl+k ctrl+oem_2",
        "when": "editorTextFocus && !editorReadonly && editorLangId == cobol"
      }
    ],
    "commands": [
      {
        "command": "cobolLens.showRecordLayout",
        "title": "%cobolLens.command.showRecordLayout.title%"
      },
      {
        "command": "cobolLens.expandCopybook",
        "title": "%cobolLens.command.expandCopybook.title%"
      },
      {
        "command": "cobolLens.refreshCopyTree",
        "title": "%cobolLens.command.refreshCopyTree.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "cobolLens.formatDocument",
        "title": "%cobolLens.command.formatDocument.title%"
      },
      {
        "command": "cobolLens.formatSelection",
        "title": "%cobolLens.command.formatSelection.title%"
      },
      {
        "command": "cobolLens.toggleComment",
        "title": "%cobolLens.command.toggleComment.title%"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "cobolLens.showRecordLayout",
          "when": "editorLangId == cobol"
        },
        {
          "command": "cobolLens.expandCopybook",
          "when": "editorLangId == cobol"
        },
        {
          "command": "cobolLens.formatDocument",
          "when": "editorLangId == cobol"
        },
        {
          "command": "cobolLens.formatSelection",
          "when": "editorLangId == cobol"
        },
        {
          "command": "cobolLens.toggleComment",
          "when": "editorLangId == cobol"
        }
      ],
      "editor/context": [
        {
          "command": "cobolLens.toggleComment",
          "when": "editorLangId == cobol",
          "group": "1_modification@1"
        },
        {
          "command": "cobolLens.formatSelection",
          "when": "editorLangId == cobol && editorHasSelection",
          "group": "1_modification@2"
        },
        {
          "command": "cobolLens.formatDocument",
          "when": "editorLangId == cobol",
          "group": "1_modification@3"
        },
        {
          "command": "cobolLens.showRecordLayout",
          "when": "editorLangId == cobol",
          "group": "navigation@9"
        },
        {
          "command": "cobolLens.expandCopybook",
          "when": "editorLangId == cobol",
          "group": "navigation@10"
        }
      ],
      "view/title": [
        {
          "command": "cobolLens.refreshCopyTree",
          "when": "view == cobolLensCopyTree",
          "group": "navigation"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "cobolLensCopyTree",
          "name": "%cobolLens.view.copyTree.name%",
          "icon": "$(references)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "cobolLensCopyTree",
        "contents": "%cobolLens.view.copyTree.empty%"
      }
    ],
    "walkthroughs": [
      {
        "id": "cobolLens.gettingStarted",
        "title": "%cobolLens.walkthrough.title%",
        "description": "%cobolLens.walkthrough.description%",
        "steps": [
          {
            "id": "welcome",
            "title": "%cobolLens.walkthrough.welcome.title%",
            "description": "%cobolLens.walkthrough.welcome.description%",
            "media": { "markdown": "media/walkthrough/welcome.md" }
          },
          {
            "id": "navigation",
            "title": "%cobolLens.walkthrough.navigation.title%",
            "description": "%cobolLens.walkthrough.navigation.description%",
            "media": { "markdown": "media/walkthrough/navigation.md" }
          },
          {
            "id": "layout",
            "title": "%cobolLens.walkthrough.layout.title%",
            "description": "%cobolLens.walkthrough.layout.description%",
            "media": { "markdown": "media/walkthrough/layout.md" },
            "completionEvents": ["onCommand:cobolLens.showRecordLayout"]
          },
          {
            "id": "linter",
            "title": "%cobolLens.walkthrough.linter.title%",
            "description": "%cobolLens.walkthrough.linter.description%",
            "media": { "markdown": "media/walkthrough/linter.md" }
          },
          {
            "id": "ifblocks",
            "title": "%cobolLens.walkthrough.ifblocks.title%",
            "description": "%cobolLens.walkthrough.ifblocks.description%",
            "media": { "markdown": "media/walkthrough/ifblocks.md" }
          },
          {
            "id": "completion",
            "title": "%cobolLens.walkthrough.completion.title%",
            "description": "%cobolLens.walkthrough.completion.description%",
            "media": { "markdown": "media/walkthrough/completion.md" }
          },
          {
            "id": "configure",
            "title": "%cobolLens.walkthrough.configure.title%",
            "description": "%cobolLens.walkthrough.configure.description%",
            "media": { "markdown": "media/walkthrough/configure.md" },
            "completionEvents": ["onCommand:workbench.action.openSettings"]
          }
        ]
      }
    ],
    "configuration": {
      "title": "COBOL Lens",
